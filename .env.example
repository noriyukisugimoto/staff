# PostgreSQL（本番・開発とも Neon 等の接続文字列を推奨）
# 例: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 開発: http://localhost:3000 ／ 本番: https://あなたのドメイン
NEXTAUTH_URL="http://localhost:3000"

# 十分に長いランダム文字列（本番では必ず別の値にする）
NEXTAUTH_SECRET="replace-with-strong-random-secret"
